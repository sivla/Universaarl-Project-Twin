# Standardquelle ist der Geschwisterordner ..\Universaarl Projekt BC Basic.
# Optionaler lokaler Override: absoluter Pfad zu einem Checkout derselben gebundenen Blueprint-Quelle.
# Erwartet werden https://github.com/sivla/FiBu.git und der Branch codex/universaarl-projekt.
# Der Pfad wird niemals an die Benutzeroberfläche ausgeliefert; die Auswahl allein ist keine Freigabe.
UABC_SOURCE_REPO=
# Zwingend: vollständige, validierte 40-stellige Commit-SHA der Kundeninstanz.
# Ohne diese SHA bleibt die Quelle sicher gesperrt; Remote und Branch sind zusätzliche Prüfungen.
UABC_EXPECTED_COMMIT=
